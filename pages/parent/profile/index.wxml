<!-- pages/parent/profile/index.wxml -->
<view class="container">

  <!-- 个人信息区域 -->
  <view class="profile-card">
    <view class="profile-info" bindtap="onEditProfile">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="profile-text">
        <text class="nick-name">{{userInfo.nickName || '家长'}}</text>
        <text class="user-code">编号：{{userInfo.userCode || ''}}</text>
      </view>
    </view>
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-icon">⏻</text>
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 学生列表标题 -->
  <view class="section-header">
    <text class="section-title">关联的学生</text>
    <text class="section-count">{{studentList.length}}人</text>
  </view>

  <!-- 学生网格 -->
  <view class="class-grid">
    <!-- 关联学生卡片 -->
    <view class="class-card add-card" bindtap="onLinkStudent">
      <text class="add-icon">+</text>
      <text class="add-text">关联学生</text>
    </view>

    <!-- 已有学生卡片 -->
    <view class="class-card" wx:for="{{studentList}}" wx:key="_id" bindtap="onStudentDetail" data-id="{{item._id}}" data-studentid="{{item.studentId}}">
      <view class="card-bg" style="background: linear-gradient(135deg, {{item.bgColor}} 0%, {{item.bgColor2}} 100%);"></view>
      <view class="card-overlay">
        <text class="card-name">{{item.studentName}}</text>
        <text class="card-code">🔑 {{item.studentCode}}</text>
      </view>
    </view>
  </view>

</view>

<!-- 关联学生弹窗 -->
<view class="modal-mask" wx:if="{{showLinkModal}}" bindtap="onCloseLinkModal"></view>
<view class="modal-dialog" wx:if="{{showLinkModal}}">
  <text class="modal-title">关联学生</text>
  <text class="modal-desc">输入学生的6位识别码进行关联</text>
  <input class="modal-input" placeholder="请输入学生识别码" value="{{studentCode}}" bindinput="onCodeInput" maxlength="6"/>
  <view class="modal-btns">
    <button class="modal-btn cancel" bindtap="onCloseLinkModal">取消</button>
    <button class="modal-btn confirm" bindtap="onConfirmLink" loading="{{linking}}">关联</button>
  </view>
</view>

<!-- 修改个人信息弹窗 -->
<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseEditModal"></view>
<view class="modal-dialog" wx:if="{{showEditModal}}">
  <text class="modal-title">修改信息</text>
  <view class="edit-avatar-wrap">
    <image class="edit-avatar" src="{{editAvatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <button class="edit-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">更换头像</button>
  </view>
  <input class="modal-input" placeholder="昵称" value="{{editNickName}}" bindinput="onEditNickNameInput"/>
  <input class="modal-input" type="number" maxlength="11" placeholder="手机号" value="{{editPhone}}" bindinput="onEditPhoneInput"/>
  <view class="modal-btns">
    <button class="modal-btn cancel" bindtap="onCloseEditModal">取消</button>
    <button class="modal-btn confirm" bindtap="onConfirmEdit" loading="{{saving}}">保存</button>
  </view>
</view>
