/* pages/parent/studentDetail/index.wxss */

page { background: #f5f5f5; }

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

/* 学生信息头部 */
.header-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.3);
}

.header-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 3rpx solid rgba(255,255,255,0.5);
  margin-right: 20rpx;
}

.student-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.invite-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
}

.invite-label, .invite-code, .copy-tip {
  color: #fff;
  font-size: 26rpx;
}

.invite-code {
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin: 0 10rpx;
}

.copy-tip {
  font-size: 22rpx;
  opacity: 0.7;
}

.meta-row {
  display: flex;
  justify-content: space-between;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 班级列表标题 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-icon {
  font-size: 32rpx;
}

/* 班级列表 */
.class-list {
  margin-bottom: 30rpx;
}

.class-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.class-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.class-code {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 2rpx;
}

.class-meta {
  display: flex;
  justify-content: space-between;
}

.class-count, .class-time {
  font-size: 22rpx;
  color: #999;
}

.empty-class {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部 */
.bottom-actions {
  padding: 20rpx 0;
  padding-bottom: 40rpx;
}

.unlink-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #e74c3c;
  border-radius: 20rpx;
  color: #e74c3c;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
