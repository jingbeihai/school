<!-- pages/parent/homeworkDetail/index.wxml -->
<view class="container">

  <!-- 头部 -->
  <view class="header">
    <view class="h-top">
      <text class="h-back" bindtap="onBack">← 返回</text>
      <text class="h-title">{{homeworkInfo.title || '作业详情'}}</text>
      <text class="h-score" wx:if="{{answeredCount > 0}}">{{correctCount}}/{{answeredCount}} 正确</text>
    </view>
  </view>

  <!-- 题号导航（含作答状态色） -->
  <view class="nav-bar" wx:if="{{questions.length > 0}}">
    <scroll-view class="nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="nav-nums">
        <view class="nav-num {{idx === currentIndex ? 'active' : ''}} {{item.isCorrect === true ? 'correct' : (item.isCorrect === false ? 'wrong' : '')}}"
              wx:for="{{questions}}" wx:key="_id"
              wx:for-index="idx" data-index="{{idx}}"
              bindtap="onJumpTo">
          {{idx + 1}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{questions.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无题目</text>
  </view>

  <!-- 单题展示 -->
  <view class="q-single" wx:if="{{questions.length > 0}}">
    <view class="q-header">
      <text class="q-index">{{studentName ? studentName + ' · ' : ''}}第{{currentIndex + 1}}题</text>
      <text class="q-type type-{{questions[currentIndex].type}}">{{typeLabel[questions[currentIndex].type]}}</text>
      <text class="q-diff diff-{{questions[currentIndex].difficulty}}">{{diffLabel[questions[currentIndex].difficulty]}}</text>
      <block wx:if="{{questions[currentIndex].hasSubmitted}}">
        <text wx:if="{{questions[currentIndex].isCorrect}}" class="q-result correct">✓ 正确</text>
        <text wx:if="{{!questions[currentIndex].isCorrect}}" class="q-result wrong">✗ 错误</text>
      </block>
      <text wx:if="{{!questions[currentIndex].hasSubmitted}}" class="q-submitted-tag" style="background:#fff3e0;color:#f39c12;">未作答</text>
    </view>

    <view class="q-content">{{questions[currentIndex].content}}</view>

    <!-- 选择题：正确项绿色 + 学生错选项红色 -->
    <view class="q-options" wx:if="{{questions[currentIndex].type === 'single_choice' || questions[currentIndex].type === 'multiple_choice'}}">
      <view class="q-option {{opt.letter === questions[currentIndex].answer || (questions[currentIndex].answer && questions[currentIndex].answer.indexOf(opt.letter) >= 0) ? 'opt-correct' : (questions[currentIndex].userAnswer && questions[currentIndex].userAnswer.indexOf(opt.letter) >= 0 && !questions[currentIndex].isCorrect ? 'opt-wrong' : '')}}"
            wx:for="{{questions[currentIndex].options}}" wx:for-item="opt" wx:key="letter">
        <text class="opt-label">{{opt.letter}}.</text>
        <text class="opt-text">{{opt.text}}</text>
      </view>
    </view>

    <!-- 学生答案行 -->
    <view class="q-answer-row" wx:if="{{questions[currentIndex].hasSubmitted}}">
      <text class="q-label">学生作答：</text>
      <text class="q-user-ans {{questions[currentIndex].isCorrect ? 'ans-correct' : 'ans-wrong'}}">{{questions[currentIndex].userAnswerDisplay || questions[currentIndex].userAnswer || '未作答'}}</text>
    </view>

    <!-- 正确答案 -->
    <view class="q-answer-row">
      <text class="q-label">正确答案：</text>
      <text class="q-correct-ans">{{questions[currentIndex].answerDisplay || questions[currentIndex].answer}}</text>
    </view>

    <!-- 解析 -->
    <view class="q-explanation" wx:if="{{questions[currentIndex].explanation}}">
      <text class="q-label">解析：</text>
      <text class="q-exp-text">{{questions[currentIndex].explanation}}</text>
    </view>

    <!-- 教师评语 -->
    <view class="q-comment" wx:if="{{questions[currentIndex].teacherComment}}">
      <text class="q-label">教师评语：</text>
      <text class="q-comment-text">{{questions[currentIndex].teacherComment}}</text>
    </view>
  </view>

  <!-- 上一题 / 下一题 -->
  <view class="nav-btns" wx:if="{{questions.length > 0}}">
    <button class="nav-btn" bindtap="onPrev" disabled="{{currentIndex === 0}}">← 上一题</button>
    <text class="nav-info">{{currentIndex + 1}}/{{questions.length}}</text>
    <button class="nav-btn" bindtap="onNext" disabled="{{currentIndex >= questions.length - 1}}">下一题 →</button>
  </view>

</view>
