/* pages/login/index.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 50rpx;
  box-sizing: border-box;
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 角色选择 */
.role-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.role-buttons {
  display: flex;
  justify-content: space-between;
}

.role-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  margin: 0 10rpx;
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
}

.role-btn.active {
  background-color: #e8f0fe;
  border-color: #667eea;
  transform: scale(1.05);
}

.role-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.role-text {
  font-size: 28rpx;
  color: #666;
}

.role-btn.active .role-text {
  color: #667eea;
  font-weight: 600;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  border: none;
  margin-bottom: 30rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  background: #aaa;
  box-shadow: none;
}

.loading-text {
  font-size: 28rpx;
}

/* 提示 */
.tips {
  text-align: center;
  padding: 0 20rpx;
}

.tip-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}
