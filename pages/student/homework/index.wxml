<!-- pages/student/homework/index.wxml -->
<view class="container">

  <view class="hint-bar" wx:if="{{list.length > 0}}">
    <text>📋 共 {{list.length}} 项作业</text>
  </view>

  <!-- 作业列表 -->
  <view class="hw-list" wx:if="{{list.length > 0}}">
    <view class="hw-card {{item.answeredCount >= item.totalCount && item.totalCount > 0 ? 'done' : ''}}" 
          wx:for="{{list}}" wx:key="_id" 
          bindtap="goHomework" 
          data-id="{{item._id}}" 
          data-answered="{{item.answeredCount}}"
          data-total="{{item.totalCount}}">
      <view class="hw-title">{{item.title}}</view>
      <view class="hw-meta">
        <text class="hw-class">🏫 {{item.className}}</text>
        <text class="hw-deadline">⏰ 截止 {{item.deadline}}</text>
      </view>
      <view class="hw-footer">
        <text class="hw-time">发布于 {{item.publishTime}}</text>
        <view class="hw-stats">
          <text class="hw-stat-item" wx:if="{{item.answeredCount > 0}}">
            完成度 <text class="stat-num">{{item.answeredCount}}/{{item.totalCount}}</text>
          </text>
          <text class="hw-stat-item" wx:if="{{item.answeredCount >= item.totalCount && item.totalCount > 0}}">
            正确率 <text class="stat-num {{item.correctCount === item.totalCount ? 'perfect' : ''}}">{{item.correctCount}}/{{item.totalCount}}</text>
          </text>
          <text wx:if="{{item.answeredCount === 0}}" class="hw-stat-item pending-text">📝 未开始</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无作业</text>
    <text class="empty-sub">加入班级后，老师发布的作业会显示在这里</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

</view>
