/* pages/student/homework/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.hint-bar {
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
}

/* 作业卡片 */
.hw-list {
  padding: 0 30rpx;
}

.hw-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
}

.hw-card.done {
  opacity: 0.75;
}

.hw-card.has-notify {
  border: 2rpx solid #667eea;
}

.hw-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hw-new-badge {
  font-size: 20rpx;
  background: #ff4757;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.hw-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 14rpx;
}

.hw-class {
  color: #667eea;
}

.hw-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hw-time {
  font-size: 22rpx;
  color: #bbb;
}

.hw-stats {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.hw-stat-item {
  font-size: 22rpx;
  color: #888;
}

.stat-num {
  font-weight: 600;
  color: #667eea;
}

.stat-num.perfect {
  color: #27ae60;
}

.pending-text {
  color: #f39c12;
  font-size: 22rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 24rpx;
  color: #ccc;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 26rpx;
}
