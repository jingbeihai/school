/* pages/student/homeworkDetail/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 20rpx 30rpx;
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 20;
}
.h-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.h-back {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
}
.h-title {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin: 0 16rpx;
}
.h-score {
  font-size: 24rpx;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* ===== 题号导航 ===== */
.nav-bar {
  background: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-fixed {
  position: sticky;
  top: 80rpx;
  z-index: 15;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.nav-top-row {
  display: flex;
  align-items: center;
}
.nav-scroll {
  flex: 1;
  white-space: nowrap;
}
.nav-select-all {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.nav-nums {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}
.nav-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  background: #f0f0f0;
  color: #999;
  flex-shrink: 0;
  transition: all 0.2s;
}
.nav-num.active {
  background: #667eea;
  color: #fff;
  transform: scale(1.1);
}
.nav-num.correct {
  background: #e8f5e9;
  color: #27ae60;
  border: 2rpx solid #27ae60;
}
.nav-num.wrong {
  background: #fdecea;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}
.nav-num.active.correct {
  background: #27ae60;
  color: #fff;
}
.nav-num.active.wrong {
  background: #e74c3c;
  color: #fff;
}
.nav-num.checked {
  box-shadow: 0 0 0 3rpx #ffa000;
}

.nav-progress {
  text-align: right;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

/* ===== 单题卡片 ===== */
.q-single {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.q-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.q-index {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 16rpx;
}
.q-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
  color: #fff;
}
.type-single_choice { background: #5dade2; }
.type-multiple_choice { background: #f39c12; }
.type-fill_blank { background: #27ae60; }
.type-essay { background: #8e44ad; }

.q-diff {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}
.diff-easy { background: #27ae60; }
.diff-medium { background: #f39c12; }
.diff-hard { background: #e74c3c; }

.q-result {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: auto;
}
.q-result.correct { background: #e8f5e9; color: #27ae60; }
.q-result.wrong { background: #fdecea; color: #e74c3c; }

.q-submitted-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #e8f5e9;
  color: #27ae60;
  margin-left: auto;
}

.q-fav-toggle {
  font-size: 32rpx;
  color: #ddd;
  margin-right: 12rpx;
  transition: all 0.2s;
}
.q-fav-toggle.checked {
  color: #ffa000;
}

.q-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

/* 选项 */
.q-options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.q-option {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.opt-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 12rpx;
  min-width: 36rpx;
}
.opt-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}
.q-option.opt-selected {
  background: #e8f0fe;
  border-color: #667eea;
}
.q-option.opt-correct {
  background: #e8f5e9;
  border-color: #27ae60;
}
.q-option.opt-wrong {
  background: #fdecea;
  border-color: #e74c3c;
}

/* 输入区 */
.q-input-area {
  margin-top: 10rpx;
}
.q-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #e0e0e0;
}
.q-textarea-readonly {
  background: #f0f0f0;
  min-height: 80rpx;
  border-color: #ddd;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  white-space: pre-wrap;
}

/* 答案行 */
.q-answer-row {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  font-size: 26rpx;
}
.q-label {
  color: #888;
  white-space: nowrap;
  margin-right: 8rpx;
}
.q-user-ans {
  flex: 1;
  line-height: 1.5;
}
.q-correct-ans {
  color: #27ae60;
  font-weight: 500;
  flex: 1;
  line-height: 1.5;
}
.ans-correct { color: #27ae60; font-weight: 500; }
.ans-wrong { color: #e74c3c; font-weight: 500; }

.q-explanation {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f0f4ff;
  border-radius: 10rpx;
  border-left: 6rpx solid #667eea;
}
.q-exp-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 教师评语 */
.q-comment {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff8e1;
  border-radius: 10rpx;
  border-left: 6rpx solid #f39c12;
}
.q-comment-text {
  font-size: 24rpx;
  color: #8d6e00;
  line-height: 1.6;
}

/* 提交此题 */
.q-submit-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}
.q-submit-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.q-submit-btn[disabled] {
  background: #ccc;
}

/* 提交结果 */
.q-result-row {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
}
.result-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.result-correct {
  background: #e8f5e9;
  color: #27ae60;
}
.result-wrong {
  background: #fdecea;
  color: #e74c3c;
}

/* ===== 收藏此题 ===== */
.fav-current-row {
  display: flex;
  justify-content: center;
  padding: 0 30rpx 20rpx;
}
.fav-current-btn {
  width: 100%;
  height: 72rpx;
  background: #fff;
  color: #667eea;
  font-size: 26rpx;
  border-radius: 36rpx;
  border: 2rpx solid #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 上一题/下一题 ===== */
.nav-btns {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 20rpx 30rpx;
}
.nav-btn {
  flex: 1;
  height: 72rpx;
  background: #667eea;
  color: #fff;
  font-size: 26rpx;
  border-radius: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-btn[disabled] {
  background: #ddd;
  color: #aaa;
}
.nav-info {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  white-space: nowrap;
}

/* ===== 收藏底部栏 ===== */
.fav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom) + 100rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 10;
}
.fav-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

/* ===== 弹窗 ===== */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.modal-content {
  position: relative; width: 100%; background: #fff;
  border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx;
  max-height: 70vh; overflow-y: auto;
}
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 30rpx; }

.fav-section { margin-bottom: 30rpx; }
.fav-section-title { font-size: 26rpx; color: #999; margin-bottom: 16rpx; display: block; }
.fav-group-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 24rpx; background: #f9f9f9; border-radius: 12rpx;
  margin-bottom: 12rpx; font-size: 28rpx;
}
.fav-group-item.active { background: #e8eaff; color: #667eea; border: 2rpx solid #667eea; }
.fav-count { font-size: 22rpx; color: #999; }
.fav-empty-tip { font-size: 24rpx; color: #ccc; text-align: center; padding: 20rpx 0; }
.fav-input {
  width: 100%; height: 80rpx; background: #f9f9f9; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box;
}

.modal-btns { display: flex; gap: 24rpx; margin-top: 10rpx; }
.btn-cancel, .btn-confirm { flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; border: none; }
.btn-cancel { background: #f0f0f0; color: #666; }
.btn-confirm { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
