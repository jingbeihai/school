/* pages/student/homeworkDetail/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 180rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 30rpx 30rpx 40rpx;
  color: #fff;
}
.h-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}
.h-meta {
  margin-top: 16rpx;
}
.h-score {
  font-size: 26rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.h-score.perfect {
  background: rgba(39,174,96,0.5);
}

/* 题目卡片 */
.q-list {
  padding: 20rpx 30rpx;
}
.q-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 题号行 */
.q-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.q-index {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 16rpx;
}
.q-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
  color: #fff;
}
.type-single_choice { background: #5dade2; }
.type-multiple_choice { background: #f39c12; }
.type-fill_blank { background: #27ae60; }
.type-essay { background: #8e44ad; }

.q-diff {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}
.diff-easy { background: #27ae60; }
.diff-medium { background: #f39c12; }
.diff-hard { background: #e74c3c; }

.q-result {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: auto;
}
.q-result.correct { background: #e8f5e9; color: #27ae60; }
.q-result.wrong { background: #fdecea; color: #e74c3c; }

/* 题干 */
.q-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

/* 选项 */
.q-options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.q-option {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.opt-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
  margin-right: 12rpx;
  min-width: 36rpx;
}
.opt-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}
.q-option.opt-selected {
  background: #e8f0fe;
  border-color: #667eea;
}
.q-option.opt-correct {
  background: #e8f5e9;
  border-color: #27ae60;
}
.q-option.opt-wrong {
  background: #fdecea;
  border-color: #e74c3c;
}

/* 填空/简答输入 */
.q-input-area {
  margin-top: 10rpx;
}
.q-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #e0e0e0;
}

/* 已提交答案展示 */
.q-answer-row {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  font-size: 26rpx;
}
.q-label {
  color: #888;
  white-space: nowrap;
  margin-right: 8rpx;
}
.q-user-ans {
  flex: 1;
  line-height: 1.5;
}
.q-correct-ans {
  color: #27ae60;
  font-weight: 500;
  flex: 1;
  line-height: 1.5;
}
.ans-correct { color: #27ae60; font-weight: 500; }
.ans-wrong { color: #e74c3c; font-weight: 500; }

.q-explanation {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f0f4ff;
  border-radius: 10rpx;
  border-left: 6rpx solid #667eea;
}
.q-exp-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom) + 100rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 10;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.submit-btn[disabled] {
  opacity: 0.7;
}

/* 收藏选择栏 */
.fav-select-bar {
  padding: 16rpx 30rpx;
  display: flex; justify-content: flex-end;
  background: #fff; border-bottom: 1rpx solid #f0f0f0;
}
.fav-select-bar .select-all {
  font-size: 26rpx; color: #667eea; padding: 8rpx 20rpx;
}

/* 收藏checkbox */
.q-fav-checkbox {
  margin-right: 4rpx; transform: scale(0.75);
}

/* 收藏底部栏 */
.fav-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom) + 100rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 10;
}
.fav-btn {
  width: 100%; height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 16rpx; display: flex; align-items: center;
  justify-content: center; border: none;
}

/* 弹窗 */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.modal-content {
  position: relative; width: 100%; background: #fff;
  border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx;
  max-height: 70vh; overflow-y: auto;
}
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 30rpx; }

.fav-section { margin-bottom: 30rpx; }
.fav-section-title { font-size: 26rpx; color: #999; margin-bottom: 16rpx; display: block; }
.fav-group-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 24rpx; background: #f9f9f9; border-radius: 12rpx;
  margin-bottom: 12rpx; font-size: 28rpx;
}
.fav-group-item.active { background: #e8eaff; color: #667eea; border: 2rpx solid #667eea; }
.fav-count { font-size: 22rpx; color: #999; }
.fav-empty-tip { font-size: 24rpx; color: #ccc; text-align: center; padding: 20rpx 0; }
.fav-input {
  width: 100%; height: 80rpx; background: #f9f9f9; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box;
}

.modal-btns { display: flex; gap: 24rpx; margin-top: 10rpx; }
.btn-cancel, .btn-confirm { flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; border: none; }
.btn-cancel { background: #f0f0f0; color: #666; }
.btn-confirm { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
