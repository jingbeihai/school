<!-- pages/student/homeworkDetail/index.wxml -->
<view class="container">

  <!-- 头部 -->
  <view class="header">
    <view class="h-top">
      <text class="h-back" bindtap="onBack">← 返回</text>
      <text class="h-title">{{homeworkInfo.title || '作业详情'}}</text>
      <text class="h-score" wx:if="{{answeredCount > 0}}">{{correctCount}}/{{answeredCount}} 正确</text>
    </view>
  </view>

  <!-- 已提交模式：全题展示 -->
  <block wx:if="{{submitted}}">
    <view class="nav-bar">
      <view class="nav-top-row">
        <scroll-view class="nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="nav-nums">
            <view class="nav-num {{idx === currentIndex ? 'active' : ''}} {{item.isCorrect ? 'correct' : 'wrong'}} {{item._checked ? 'checked' : ''}}"
                  wx:for="{{questions}}" wx:key="_id"
                  wx:for-index="idx" data-index="{{idx}}"
                  bindtap="onJumpTo">
              {{idx + 1}}
            </view>
          </view>
        </scroll-view>
        <text class="nav-select-all" bindtap="onToggleSelectAll">{{allChecked ? '取消全选' : '全选'}}</text>
      </view>
    </view>

    <view class="q-single" wx:if="{{questions.length > 0}}">
      <view class="q-header">
        <text class="q-fav-toggle {{questions[currentIndex]._checked ? 'checked' : ''}}" bindtap="onToggleFav" data-index="{{currentIndex}}">
          {{questions[currentIndex]._checked ? '★' : '☆'}}
        </text>
        <text class="q-index">第{{currentIndex + 1}}题</text>
        <text class="q-type type-{{questions[currentIndex].type}}">{{typeLabel[questions[currentIndex].type]}}</text>
        <text class="q-diff diff-{{questions[currentIndex].difficulty}}">{{diffLabel[questions[currentIndex].difficulty]}}</text>
        <text wx:if="{{questions[currentIndex].isCorrect}}" class="q-result correct">✓ 正确</text>
        <text wx:if="{{!questions[currentIndex].isCorrect}}" class="q-result wrong">✗ 错误</text>
      </view>

      <view class="q-content">{{questions[currentIndex].content}}</view>

      <view class="q-options" wx:if="{{questions[currentIndex].type === 'single_choice' || questions[currentIndex].type === 'multiple_choice'}}">
        <view class="q-option {{opt.letter === questions[currentIndex].answer ? 'opt-correct' : (questions[currentIndex].userAnswer && questions[currentIndex].userAnswer.indexOf(opt.letter) >= 0 && !questions[currentIndex].isCorrect ? 'opt-wrong' : '')}}"
              wx:for="{{questions[currentIndex].options}}" wx:for-item="opt" wx:key="letter">
          <text class="opt-label">{{opt.letter}}.</text>
          <text class="opt-text">{{opt.text}}</text>
        </view>
      </view>

      <view class="q-answer-row">
        <text class="q-label">你的答案：</text>
        <text class="q-user-ans {{questions[currentIndex].isCorrect ? 'ans-correct' : 'ans-wrong'}}">{{questions[currentIndex].userAnswerDisplay || questions[currentIndex].userAnswer || '未作答'}}</text>
      </view>
      <view class="q-answer-row" wx:if="{{!questions[currentIndex].isCorrect || questions[currentIndex].type === 'fill_blank' || questions[currentIndex].type === 'essay'}}">
        <text class="q-label">正确答案：</text>
        <text class="q-correct-ans">{{questions[currentIndex].answer}}</text>
      </view>
      <view class="q-explanation" wx:if="{{questions[currentIndex].explanation}}">
        <text class="q-label">解析：</text>
        <text class="q-exp-text">{{questions[currentIndex].explanation}}</text>
      </view>

      <!-- 教师评语 -->
      <view class="q-comment" wx:if="{{questions[currentIndex].comment}}">
        <text class="q-label">教师评语：</text>
        <text class="q-comment-text">{{questions[currentIndex].comment}}</text>
      </view>
    </view>

    <!-- 上一题 / 下一题 -->
    <view class="nav-btns">
      <button class="nav-btn" bindtap="onPrev" disabled="{{currentIndex === 0}}">← 上一题</button>
      <text class="nav-info">{{currentIndex + 1}}/{{questions.length}}</text>
      <button class="nav-btn" bindtap="onNext" disabled="{{currentIndex >= questions.length - 1}}">下一题 →</button>
    </view>

    <!-- 收藏此题 -->
    <view class="fav-current-row">
      <button class="fav-current-btn" bindtap="onFavCurrent">☆ 收藏此题</button>
    </view>
  </block>

  <!-- 未提交/答题模式：题号导航 + 单题 -->
  <block wx:if="{{!submitted}}">
    <!-- 固定题号导航 -->
    <view class="nav-bar nav-fixed">
      <scroll-view class="nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="nav-nums">
          <view class="nav-num {{idx === currentIndex ? 'active' : ''}} {{submittedQuestions[item._id] ? (questionResults[item._id] && questionResults[item._id].isCorrect ? 'correct' : 'wrong') : ''}}"
                wx:for="{{questions}}" wx:key="_id"
                wx:for-index="idx" data-index="{{idx}}"
                bindtap="onJumpTo">
            {{idx + 1}}
          </view>
        </view>
      </scroll-view>
      <view class="nav-progress">
        <text>已完成 {{currentAnsweredCount}}/{{questions.length}}</text>
      </view>
    </view>

    <!-- 单题展示 -->
    <view class="q-single" wx:if="{{questions.length > 0}}">
      <view class="q-header">
        <text class="q-index">第{{currentIndex + 1}}题</text>
        <text class="q-type type-{{questions[currentIndex].type}}">{{typeLabel[questions[currentIndex].type]}}</text>
        <text class="q-diff diff-{{questions[currentIndex].difficulty}}">{{diffLabel[questions[currentIndex].difficulty]}}</text>
        <text wx:if="{{submittedQuestions[questions[currentIndex]._id]}}" class="q-submitted-tag">已提交</text>
      </view>

      <view class="q-content">{{questions[currentIndex].content}}</view>

      <!-- 选择题 -->
      <view class="q-options" wx:if="{{questions[currentIndex].type === 'single_choice' || questions[currentIndex].type === 'multiple_choice'}}">
        <!-- 未提交：可作答 -->
        <block wx:if="{{!submittedQuestions[questions[currentIndex]._id]}}">
          <view class="q-option {{questions[currentIndex].type === 'single_choice' ? (answers[questions[currentIndex]._id] === opt.letter ? 'opt-selected' : '') : (answers[questions[currentIndex]._id] && answers[questions[currentIndex]._id].indexOf(opt.letter) >= 0 ? 'opt-selected' : '')}}"
                wx:for="{{questions[currentIndex].options}}" wx:for-item="opt" wx:key="letter"
                data-qid="{{questions[currentIndex]._id}}" data-opt="{{opt.letter}}"
                bindtap="{{questions[currentIndex].type === 'single_choice' ? 'onSingleChoice' : 'onMultiChoice'}}">
            <text class="opt-label">{{opt.letter}}.</text>
            <text class="opt-text">{{opt.text}}</text>
          </view>
        </block>
        <!-- 已提交：显示对错 -->
        <block wx:if="{{submittedQuestions[questions[currentIndex]._id]}}">
          <view class="q-option {{opt.letter === questionResults[questions[currentIndex]._id].correctAnswer ? 'opt-correct' : (answers[questions[currentIndex]._id] && answers[questions[currentIndex]._id].indexOf(opt.letter) >= 0 && !questionResults[questions[currentIndex]._id].isCorrect ? 'opt-wrong' : '')}}"
                wx:for="{{questions[currentIndex].options}}" wx:for-item="opt" wx:key="letter">
            <text class="opt-label">{{opt.letter}}.</text>
            <text class="opt-text">{{opt.text}}</text>
          </view>
        </block>
      </view>

      <!-- 填空/简答 -->
      <view class="q-input-area" wx:if="{{questions[currentIndex].type === 'fill_blank' || questions[currentIndex].type === 'essay'}}">
        <textarea class="q-textarea"
                  wx:if="{{!submittedQuestions[questions[currentIndex]._id]}}"
                  placeholder="{{questions[currentIndex].type === 'essay' ? '请输入你的答案...' : '请填写答案'}}"
                  value="{{answers[questions[currentIndex]._id] || ''}}"
                  data-qid="{{questions[currentIndex]._id}}"
                  bindinput="onTextInput"
                  maxlength="2000"
                  auto-height />
        <view wx:if="{{submittedQuestions[questions[currentIndex]._id]}}" class="q-textarea-readonly">
          <text>{{answers[questions[currentIndex]._id] || '未作答'}}</text>
        </view>
      </view>

      <!-- 提交此题按钮 -->
      <view class="q-submit-row" wx:if="{{!submittedQuestions[questions[currentIndex]._id]}}">
        <button class="q-submit-btn" bindtap="onSubmitQuestion" data-qid="{{questions[currentIndex]._id}}"
                loading="{{submittingQuestionId === questions[currentIndex]._id}}" 
                disabled="{{submittingQuestionId && submittingQuestionId !== questions[currentIndex]._id}}">
          提交此题
        </button>
      </view>

      <!-- 已提交：显示结果 -->
      <block wx:if="{{submittedQuestions[questions[currentIndex]._id]}}">
        <view class="q-result-row {{questionResults[questions[currentIndex]._id].isCorrect ? 'result-correct' : 'result-wrong'}}">
          <text wx:if="{{questionResults[questions[currentIndex]._id].isCorrect}}" class="result-icon">✓</text>
          <text wx:if="{{!questionResults[questions[currentIndex]._id].isCorrect}}" class="result-icon">✗</text>
          <text wx:if="{{questionResults[questions[currentIndex]._id].isCorrect}}">回答正确</text>
          <text wx:if="{{!questionResults[questions[currentIndex]._id].isCorrect}}">回答错误</text>
        </view>
        <view class="q-answer-row" wx:if="{{!questionResults[questions[currentIndex]._id].isCorrect}}">
          <text class="q-label">正确答案：</text>
          <text class="q-correct-ans">{{questionResults[questions[currentIndex]._id].correctAnswer}}</text>
        </view>
        <view class="q-explanation" wx:if="{{questionResults[questions[currentIndex]._id].explanation}}">
          <text class="q-label">解析：</text>
          <text class="q-exp-text">{{questionResults[questions[currentIndex]._id].explanation}}</text>
        </view>
      </block>
    </view>

    <!-- 上一题 / 下一题 -->
    <view class="nav-btns">
      <button class="nav-btn" bindtap="onPrev" disabled="{{currentIndex === 0}}">← 上一题</button>
      <text class="nav-info">{{currentIndex + 1}}/{{questions.length}}</text>
      <button class="nav-btn" bindtap="onNext" disabled="{{currentIndex >= questions.length - 1}}">下一题 →</button>
    </view>

    <!-- 收藏此题 -->
    <view class="fav-current-row">
      <button class="fav-current-btn" bindtap="onFavCurrent">☆ 收藏此题</button>
    </view>
  </block>

  <!-- 收藏按钮（已提交模式） -->
  <view class="fav-bar" wx:if="{{submitted && questions.length}}">
    <button class="fav-btn" bindtap="onOpenFavModal">📁 收藏到组（{{favSelectedCount}}题已选）</button>
  </view>

  <!-- 收藏弹窗 -->
  <view class="modal" wx:if="{{showFavModal}}">
    <view class="modal-mask" bindtap="closeFavModal"></view>
    <view class="modal-content">
      <text class="modal-title">收藏到组</text>
      <view class="fav-section">
        <text class="fav-section-title">选择已有收藏组</text>
        <view class="fav-group-item {{selFavGroupId===item._id?'active':''}}"
              wx:for="{{favGroups}}" wx:key="_id"
              bindtap="onSelectFavGroup" data-id="{{item._id}}">
          <text>{{item.name}}</text>
          <text class="fav-count">{{item.questionCount || 0}}题</text>
        </view>
        <view wx:if="{{favGroups.length===0}}" class="fav-empty-tip">暂无收藏组</view>
      </view>
      <view class="fav-section">
        <text class="fav-section-title">或创建新收藏组</text>
        <input class="fav-input" placeholder="输入新组名称"
               value="{{favNewName}}" bindinput="onFavNewNameInput" maxlength="20" />
      </view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeFavModal">取消</button>
        <button class="btn-confirm" bindtap="confirmFav">确认收藏</button>
      </view>
    </view>
  </view>

</view>