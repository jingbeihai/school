/* pages/student/classDetail/index.wxss */

page { background: #f5f5f5; }

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

/* 班级信息头部（与教师端一致） */
.header-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.3);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.class-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.invite-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
}

.invite-label, .invite-code, .copy-tip {
  color: #fff;
  font-size: 26rpx;
}

.invite-code {
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin: 0 10rpx;
}

.copy-tip {
  font-size: 22rpx;
  opacity: 0.7;
}

.meta-row {
  display: flex;
  justify-content: space-between;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 教师信息卡片 */
.teacher-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-icon {
  font-size: 32rpx;
}

.teacher-content {
  display: flex;
  align-items: center;
}

.teacher-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #eee;
  margin-right: 24rpx;
}

.teacher-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.teacher-code {
  font-size: 24rpx;
  color: #999;
}

.teacher-phone {
  font-size: 24rpx;
  color: #999;
}

/* 底部 */
.bottom-actions {
  padding: 20rpx 0;
  padding-bottom: 40rpx;
}

.leave-class-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #e74c3c;
  border-radius: 20rpx;
  color: #e74c3c;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
