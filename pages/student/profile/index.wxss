/* pages/student/profile/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 个人信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.profile-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #eee;
  margin-right: 24rpx;
}

.profile-text {
  display: flex;
  flex-direction: column;
}

.nick-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.user-code {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.logout-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.logout-icon {
  font-size: 40rpx;
  color: #999;
}

.logout-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 班级区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

/* 班级网格 */
.class-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
}

.class-card {
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.card-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
  padding: 24rpx 18rpx;
}

.card-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-teacher {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-code {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
  display: block;
  letter-spacing: 2rpx;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.card-count {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.card-time {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

/* 加入班级卡片 */
.add-card {
  background: #fff;
  border: 4rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  font-weight: 300;
}

.add-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 101;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* 编辑头像 */
.edit-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.edit-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #eee;
  margin-bottom: 16rpx;
}
.edit-avatar-btn {
  font-size: 24rpx;
  color: #667eea;
  background: transparent;
  border: none;
  padding: 0;
  line-height: 1.4;
}
.edit-avatar-btn::after {
  border: none;
}

.modal-btns {
  display: flex;
  justify-content: flex-end;
  margin-top: 30rpx;
}

.modal-btn {
  width: 160rpx;
  height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #667eea;
  color: #fff;
}
