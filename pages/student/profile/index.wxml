<!-- pages/student/profile/index.wxml -->
<view class="container">

  <!-- 个人信息区域 -->
  <view class="profile-card">
    <view class="profile-info" bindtap="onEditProfile">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="profile-text">
        <text class="nick-name">{{userInfo.nickName || '学生'}}</text>
        <text class="user-code">编号：{{userInfo.userCode || ''}}</text>
      </view>
    </view>
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-icon">⏻</text>
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 班级列表标题 -->
  <view class="section-header">
    <text class="section-title">加入的班级</text>
    <text class="section-count">{{classList.length}}个</text>
  </view>

  <!-- 班级网格 -->
  <view class="class-grid">
    <!-- 加入班级卡片 -->
    <view class="class-card add-card" bindtap="onJoinClass">
      <text class="add-icon">+</text>
      <text class="add-text">加入班级</text>
    </view>

    <!-- 已有班级卡片 -->
    <view class="class-card" wx:for="{{classList}}" wx:key="_id" bindtap="onOpenClass" data-id="{{item._id}}">
      <view class="card-bg" style="background: linear-gradient(135deg, {{item.bgColor || '#667eea'}} 0%, {{item.bgColor2 || '#764ba2'}} 100%);"></view>
      <view class="card-overlay">
        <text class="card-name">{{item.name}}</text>
        <text class="card-count">{{item.studentCount || 0}}名同学</text>
      </view>
    </view>
  </view>

</view>

<!-- 加入班级弹窗 -->
<view class="modal-mask" wx:if="{{showJoinModal}}" bindtap="onCloseJoinModal"></view>
<view class="modal-dialog" wx:if="{{showJoinModal}}">
  <text class="modal-title">加入班级</text>
  <text class="modal-desc">输入老师提供的邀请码即可加入</text>
  <input class="modal-input" placeholder="请输入邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" maxlength="6"/>
  <view class="modal-btns">
    <button class="modal-btn cancel" bindtap="onCloseJoinModal">取消</button>
    <button class="modal-btn confirm" bindtap="onConfirmJoin" loading="{{joining}}">加入</button>
  </view>
</view>

<!-- 修改个人信息弹窗 -->
<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseEditModal"></view>
<view class="modal-dialog" wx:if="{{showEditModal}}">
  <text class="modal-title">修改信息</text>
  <view class="edit-avatar-wrap">
    <image class="edit-avatar" src="{{editAvatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <button class="edit-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">更换头像</button>
  </view>
  <input class="modal-input" placeholder="昵称" value="{{editNickName}}" bindinput="onEditNickNameInput"/>
  <input class="modal-input" type="number" maxlength="11" placeholder="手机号" value="{{editPhone}}" bindinput="onEditPhoneInput"/>
  <view class="modal-btns">
    <button class="modal-btn cancel" bindtap="onCloseEditModal">取消</button>
    <button class="modal-btn confirm" bindtap="onConfirmEdit" loading="{{saving}}">保存</button>
  </view>
</view>
