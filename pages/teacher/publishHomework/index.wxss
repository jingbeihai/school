/* pages/teacher/publishHomework/index.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }

/* 选项卡 */
.tab-bar { display: flex; background: #fff; border-bottom: 1rpx solid #eee; padding: 0 20rpx; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab-item.active { color: #667eea; border-bottom-color: #667eea; font-weight: bold; }

.tab-content { padding: 30rpx; }
.input-area {
  width: 100%; min-height: 200rpx; background: #fff; border-radius: 16rpx;
  padding: 24rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 24rpx;
  border: 1rpx solid #eee;
}

.btn-primary {
  width: 100%; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; border-radius: 44rpx; font-size: 30rpx; border: none;
}
.btn-secondary {
  background: #f0f0f0; color: #333; border-radius: 16rpx; font-size: 28rpx; margin: 6rpx 0;
}

/* 上传 */
.upload-box {
  width: 200rpx; height: 200rpx; background: #fff; border: 2rpx dashed #ccc;
  border-radius: 16rpx; display: flex; align-items: center; justify-content: center; margin: 20rpx auto;
}
.upload-plus { font-size: 80rpx; color: #ccc; }
.preview-img { width: 100%; height: 100%; border-radius: 16rpx; }
.hint { text-align: center; font-size: 24rpx; color: #999; display: block; margin: 10rpx 0; }
.file-name { text-align: center; font-size: 26rpx; color: #667eea; display: block; margin: 10rpx 0; }
.btn-row { display: flex; gap: 20rpx; padding: 0 30rpx; }

/* 题目列表 */
.question-section { padding: 0 24rpx 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 10rpx; }
.back-btn { font-size: 26rpx; color: #667eea; flex-shrink: 0; margin-right: 16rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; }
.select-all { font-size: 26rpx; color: #667eea; }

.question-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.q-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.q-checkbox { margin-right: 12rpx; transform: scale(0.8); }
.q-index { font-size: 26rpx; color: #999; margin-right: 16rpx; }
.q-type {
  font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; margin-right: 10rpx;
  color: #fff; background: #5dade2;
}
.q-type.multiple_choice { background: #f39c12; }
.q-type.fill_blank { background: #27ae60; }
.q-type.essay { background: #8e44ad; }
.q-diff {
  font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; color: #fff;
}
.q-diff.easy { background: #27ae60; }
.q-diff.medium { background: #f39c12; }
.q-diff.hard { background: #e74c3c; }
.q-content { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 12rpx; }
.q-options { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 12rpx; }
.q-options text { font-size: 24rpx; background: #f5f5f5; padding: 6rpx 16rpx; border-radius: 8rpx; color: #555; }
.q-answer { font-size: 26rpx; color: #27ae60; margin-bottom: 6rpx; }
.q-explanation { font-size: 24rpx; color: #999; }

/* 底部操作栏 */
.bottom-bar {
  display: flex; gap: 24rpx;
  padding: 20rpx 0;
}
.btn-bar {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx;
  background: #f0f0f0; color: #333; border: none;
}
.btn-bar.primary { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }

/* 快捷入口 */
.quick-section { padding: 30rpx; }
.quick-card {
  display: flex; align-items: center; background: #fff; border-radius: 16rpx;
  padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.quick-icon { font-size: 48rpx; margin-right: 24rpx; }
.quick-info { flex: 1; }
.quick-title { font-size: 30rpx; color: #333; font-weight: bold; display: block; }
.quick-sub { font-size: 24rpx; color: #999; }
.quick-arrow { font-size: 36rpx; color: #ccc; }

/* 弹窗 */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.modal-content {
  position: relative; width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx 30rpx; max-height: 60vh; overflow-y: auto;
}
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 30rpx; }
.title-input {
  width: 100%; height: 80rpx; background: #f9f9f9; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 20rpx;
}
.class-item, .group-item {
  padding: 24rpx; background: #f9f9f9; border-radius: 12rpx; margin-bottom: 16rpx;
  font-size: 28rpx; display: flex; justify-content: space-between; align-items: center;
}
.class-item.active, .group-item.active { background: #e8eaff; color: #667eea; border: 2rpx solid #667eea; }
.group-count { font-size: 24rpx; color: #999; }
.new-group { padding: 24rpx; text-align: center; color: #667eea; font-size: 28rpx; border: 1rpx dashed #667eea; border-radius: 12rpx; margin-bottom: 16rpx; }
.modal-btns { display: flex; gap: 24rpx; margin-top: 24rpx; }
.btn-cancel, .btn-confirm {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; border: none;
}
.btn-cancel { background: #f0f0f0; color: #666; }
.btn-confirm { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
