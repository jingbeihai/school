/* pages/teacher/classDetail/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.header-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.3);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.class-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.edit-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 12rpx;
}

.invite-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
}

.invite-label, .invite-code, .copy-tip {
  color: #fff;
  font-size: 26rpx;
}

.invite-code {
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin: 0 10rpx;
}

.copy-tip {
  font-size: 22rpx;
  opacity: 0.7;
}

.meta-row {
  display: flex;
  justify-content: space-between;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 学生区域 */
.student-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.add-student-btn {
  font-size: 26rpx;
  color: #667eea;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #eee;
  margin-right: 20rpx;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.student-code {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部 */
.bottom-actions {
  padding: 20rpx 0;
}

.delete-class-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #e74c3c;
  border-radius: 20rpx;
  color: #e74c3c;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 101;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}

.modal-sub {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  justify-content: flex-end;
  margin-top: 30rpx;
}

.modal-btn {
  height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  padding: 0 30rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #667eea;
  color: #fff;
}

.modal-btn.danger {
  background: #e74c3c;
  color: #fff;
}

/* 详情行 */
.detail-rows {
  padding: 10rpx 0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.dl {
  font-size: 28rpx;
  color: #666;
}

.dv {
  font-size: 28rpx;
  color: #333;
}
