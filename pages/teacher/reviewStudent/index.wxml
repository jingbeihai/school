<view class="container">
  <!-- 顶部：学生姓名 + 正确率 -->
  <view class="top-bar">
    <text class="student-name">{{studentName}}</text>
    <text class="correct-rate">{{correctCount}}/{{totalCount}} 正确</text>
  </view>

  <view wx:if="{{!questions.length}}" class="loading">加载中...</view>

  <!-- 题目列表 -->
  <view class="question-list" wx:else>
    <view class="q-card" wx:for="{{questions}}" wx:key="questionId">
      <!-- 题号 + 是否正确 -->
      <view class="q-header">
        <text class="q-index">第{{index + 1}}题</text>
        <text class="q-result {{item.isCorrect ? 'correct' : 'wrong'}}">
          {{item.isCorrect ? '✓ 正确' : '✗ 错误'}}
        </text>
      </view>

      <!-- 题干 -->
      <view class="q-content">{{item.content}}</view>

      <!-- 选项 -->
      <view class="q-options" wx:if="{{item.options && item.options.length}}">
        <text wx:for="{{item.options}}" wx:key="index" wx:for-item="opt" class="opt-item">{{opt}}</text>
      </view>

      <!-- 学生答案 / 正确答案 -->
      <view class="q-answers">
        <view class="ans-row">
          <text class="ans-label">学生答案：</text>
          <text class="ans-val student-ans {{item.isCorrect ? '' : 'wrong'}}">{{item.userAnswer || '未作答'}}</text>
        </view>
        <view class="ans-row" wx:if="{{item.type !== 'essay'}}">
          <text class="ans-label">正确答案：</text>
          <text class="ans-val correct-ans">{{item.answer}}</text>
        </view>
        <view class="ans-row" wx:if="{{item.explanation}}">
          <text class="ans-label">解析：</text>
          <text class="ans-val explain">{{item.explanation}}</text>
        </view>
      </view>

      <!-- 单题评语 -->
      <view class="comment-box">
        <text class="comment-label">评语：</text>
        <textarea
          class="comment-input"
          placeholder="输入对该题的评语..."
          value="{{questionComments[item.questionId]}}"
          bindinput="onQuestionComment"
          data-qid="{{item.questionId}}"
          auto-height
        />
      </view>
    </view>
  </view>

  <!-- 整体评语 -->
  <view class="overall-comment" wx:if="{{questions.length}}">
    <text class="comment-title">整体评语</text>
    <textarea
      class="comment-input big"
      placeholder="输入整体评语..."
      value="{{teacherComment}}"
      bindinput="onTeacherComment"
      auto-height
    />
  </view>

  <!-- 保存按钮 -->
  <view class="bottom-bar" wx:if="{{questions.length}}">
    <button class="save-btn" bindtap="saveAllComments" loading="{{saving}}">保存评语</button>
  </view>
</view>
