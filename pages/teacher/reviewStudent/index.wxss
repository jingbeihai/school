.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 140rpx; }

.top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 30rpx; background: #fff; margin-bottom: 20rpx;
}
.student-name { font-size: 34rpx; font-weight: bold; color: #333; }
.correct-rate { font-size: 28rpx; color: #667eea; font-weight: bold; }

.loading { text-align: center; color: #999; padding-top: 200rpx; font-size: 28rpx; }

.question-list { padding: 0 24rpx; }
.q-card {
  background: #fff; border-radius: 20rpx; padding: 30rpx;
  margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.q-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.q-index { font-size: 26rpx; color: #999; }
.q-result { font-size: 26rpx; padding: 6rpx 18rpx; border-radius: 20rpx; font-weight: bold; }
.q-result.correct { color: #27ae60; background: #eafaf1; }
.q-result.wrong { color: #e74c3c; background: #fdecea; }

.q-content { font-size: 30rpx; color: #333; line-height: 1.7; margin-bottom: 16rpx; }

.q-options { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.opt-item {
  font-size: 26rpx; background: #f5f7fa; color: #555;
  padding: 10rpx 20rpx; border-radius: 10rpx;
}

.q-answers { margin-bottom: 20rpx; }
.ans-row { margin-bottom: 8rpx; display: flex; flex-wrap: wrap; }
.ans-label { font-size: 26rpx; color: #888; }
.ans-val { font-size: 26rpx; color: #333; }
.student-ans.wrong { color: #e74c3c; font-weight: bold; }
.correct-ans { color: #27ae60; font-weight: bold; }
.explain { color: #666; font-size: 24rpx; }

.comment-box {
  border-top: 1rpx solid #f0f0f0; padding-top: 20rpx;
}
.comment-label { font-size: 26rpx; color: #667eea; font-weight: bold; display: block; margin-bottom: 10rpx; }
.comment-input {
  width: 100%; min-height: 80rpx; background: #f9f9f9; border-radius: 12rpx;
  padding: 16rpx 20rpx; font-size: 26rpx; box-sizing: border-box;
}

.overall-comment {
  margin: 0 24rpx 30rpx; background: #fff; border-radius: 20rpx;
  padding: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.comment-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.comment-input.big { min-height: 140rpx; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 30rpx; background: #fff;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.1);
  z-index: 100;
}
.save-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; border-radius: 44rpx; font-size: 30rpx; border: none;
}
