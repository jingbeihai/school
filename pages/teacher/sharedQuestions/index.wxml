<!-- pages/teacher/sharedQuestions/index.wxml -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-row">
      <input class="search-input" placeholder="输入关键词（如：牛顿、函数）" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" />
      <text class="search-btn" bindtap="onSearch">搜索</text>
    </view>
    <!-- 热门标签 -->
    <view class="tag-row" wx:if="{{hotTags.length}}">
      <text class="tag-item {{activeTag===tag?'active':''}}" wx:for="{{hotTags}}" wx:key="*this" bindtap="onTagTap" data-tag="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="info-bar" wx:if="{{questions.length}}">
    <text>共 {{total}} 道题目</text>
    <text class="select-all" bindtap="onSelectAll">{{allSelected?'取消全选':'全选'}}</text>
  </view>

  <!-- 题目列表 -->
  <view wx:if="{{questions.length===0 && !loading}}" class="empty">
    <text class="empty-icon">📋</text>
    <text class="empty-text">{{keyword ? '未找到匹配的题目' : '共享题库暂无题目，教师生成题目后将自动加入'}}</text>
  </view>

  <view wx:else>
    <checkbox-group bindchange="onCheckboxChange">
      <view class="q-card" wx:for="{{questions}}" wx:key="_id">
        <view class="q-header">
          <checkbox value="{{item._id}}" checked="{{item.checked}}" class="q-checkbox" />
          <text class="q-type {{item.type}}">{{typeLabel[item.type]}}</text>
          <text class="q-diff {{item.difficulty}}">{{diffLabel[item.difficulty]}}</text>
          <text class="q-teacher">{{item.teacherName || '匿名'}}</text>
        </view>
        <view class="q-content">{{item.content}}</view>
        <view class="q-options" wx:if="{{item.options && item.options.length}}">
          <text wx:for="{{item.options}}" wx:key="index" wx:for-item="opt">{{opt}}</text>
        </view>
        <view class="q-answer">答案：{{item.answer}}</view>
        <view class="q-tags" wx:if="{{item.tags && item.tags.length}}">
          <text class="q-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
    </checkbox-group>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <button class="load-btn" bindtap="onLoadMore" loading="{{loadingMore}}">加载更多</button>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="fix-bottom" wx:if="{{questions.length}}">
    <button class="bottom-btn" bindtap="onCollectToGroup">📁 收藏到组</button>
    <button class="bottom-btn primary" bindtap="onPublishHomework">📤 发布作业</button>
  </view>

  <!-- 发布弹窗 -->
  <view class="modal" wx:if="{{showPublishModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">选择发布班级</text>
      <input class="title-input" placeholder="自定义标题（可选，如：期中复习测验）" value="{{customTitle}}" bindinput="onCustomTitle" maxlength="50" />
      <view class="class-item {{selClassId===item._id?'active':''}}" wx:for="{{classList}}" wx:key="_id" bindtap="onSelectClass" data-id="{{item._id}}">{{item.name}}</view>
      <view wx:if="{{classList.length===0}}" style="text-align:center;color:#999;padding:20rpx;">请先创建班级</view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmPublish" loading="{{publishing}}">确认发布</button>
      </view>
    </view>
  </view>

  <!-- 收藏弹窗 -->
  <view class="modal" wx:if="{{showCollectModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">添加到收藏组</text>
      <view class="group-item {{selGroupId===item._id?'active':''}}" wx:for="{{groupList}}" wx:key="_id" bindtap="onSelectGroup" data-id="{{item._id}}">
        <text>{{item.name}}</text>
        <text class="group-count">{{item.questionCount||0}}题</text>
      </view>
      <view class="new-group" bindtap="onNewGroup">+ 新建收藏组</view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmCollect" loading="{{collecting}}">确认添加</button>
      </view>
    </view>
  </view>
</view>
