/* pages/teacher/sharedQuestions/index.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }

/* 搜索栏 */
.search-bar { background: #fff; padding: 20rpx 30rpx; margin-bottom: 10rpx; }
.search-input-row { display: flex; align-items: center; background: #f5f5f5; border-radius: 36rpx; padding: 0 24rpx; height: 72rpx; }
.search-input { flex: 1; font-size: 28rpx; height: 100%; }
.search-btn { font-size: 28rpx; color: #667eea; padding-left: 20rpx; flex-shrink: 0; }
.tag-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.tag-item {
  font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx;
  background: #f0f0f0; color: #666;
}
.tag-item.active { background: #667eea; color: #fff; }

/* 信息栏 */
.info-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 30rpx; font-size: 26rpx; color: #999; }
.select-all { color: #667eea; }

/* 题目卡片 */
.q-card { background: #fff; margin: 0 20rpx 16rpx; border-radius: 12rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.q-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.q-checkbox { margin-right: 8rpx; transform: scale(0.8); }
.q-type {
  display: inline-block; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx;
  color: #fff; background: #5dade2; margin-right: 10rpx;
}
.q-type.multiple_choice { background: #f39c12; }
.q-type.fill_blank { background: #27ae60; }
.q-type.essay { background: #8e44ad; }
.q-diff { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; color: #fff; margin-right: 10rpx; }
.q-diff.easy { background: #27ae60; }
.q-diff.medium { background: #f39c12; }
.q-diff.hard { background: #e74c3c; }
.q-teacher { font-size: 22rpx; color: #999; margin-left: auto; }
.q-content { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 12rpx; }
.q-options { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 12rpx; }
.q-options text { font-size: 24rpx; background: #f5f5f5; padding: 6rpx 16rpx; border-radius: 8rpx; color: #555; }
.q-answer { font-size: 26rpx; color: #27ae60; margin-bottom: 6rpx; }
.q-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 8rpx; }
.q-tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 12rpx; background: #e8eaff; color: #667eea; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; text-align: center; padding: 0 60rpx; }

/* 加载更多 */
.load-more { padding: 20rpx; text-align: center; }
.load-btn { font-size: 26rpx; color: #667eea; background: none; border: 1rpx solid #667eea; border-radius: 30rpx; padding: 12rpx 40rpx; }

/* 底部操作栏 */
.fix-bottom {
  position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx;
  padding: 16rpx 24rpx; background: #fff; box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.1); z-index: 100;
}
.bottom-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; font-size: 28rpx; border-radius: 40rpx;
  background: #f0f0f0; color: #333; border: none;
}
.bottom-btn.primary { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }

/* 弹窗 */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.modal-content { position: relative; width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx; max-height: 60vh; overflow-y: auto; }
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; display: block; margin-bottom: 30rpx; }
.title-input {
  width: 100%; height: 80rpx; background: #f9f9f9; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 20rpx;
}
.class-item, .group-item {
  padding: 24rpx; background: #f9f9f9; border-radius: 12rpx; margin-bottom: 16rpx;
  font-size: 28rpx; display: flex; justify-content: space-between; align-items: center;
}
.class-item.active, .group-item.active { background: #e8eaff; color: #667eea; border: 2rpx solid #667eea; }
.group-count { font-size: 24rpx; color: #999; }
.new-group { padding: 24rpx; text-align: center; color: #667eea; font-size: 28rpx; border: 1rpx dashed #667eea; border-radius: 12rpx; margin-bottom: 16rpx; }
.modal-btns { display: flex; gap: 24rpx; margin-top: 24rpx; }
.btn-cancel, .btn-confirm { flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; border: none; }
.btn-cancel { background: #f0f0f0; color: #666; }
.btn-confirm { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
