<!-- pages/teacher/groupQuestions/index.wxml -->
<view class="container">
  <view class="header">
    <text class="header-name">{{group.name}}</text>
    <text class="header-meta">{{questions.length}}道题目</text>
  </view>

  <view wx:if="{{questions.length===0}}" class="empty">
    <text class="empty-icon">📋</text>
    <text class="empty-text">该组还没有题目</text>
  </view>

  <view wx:else>
    <view class="select-bar">
      <text class="select-all" bindtap="onSelectAll">{{allSelected?'取消全选':'全选'}}</text>
    </view>
    <checkbox-group bindchange="onCheckboxChange">
      <view class="q-card" wx:for="{{questions}}" wx:key="_id">
        <view class="q-header">
          <checkbox value="{{item._id}}" checked="{{item.checked}}" class="q-checkbox" />
          <text class="q-index">第{{index+1}}题</text>
          <text class="q-type {{item.type}}">{{typeLabel[item.type]}}</text>
          <text class="q-diff {{item.difficulty}}">{{diffLabel[item.difficulty]}}</text>
        </view>
        <view class="q-content">{{item.content}}</view>
        <view class="q-options" wx:if="{{item.options && item.options.length}}">
          <text wx:for="{{item.options}}" wx:key="index" wx:for-item="opt">{{opt}}</text>
        </view>
        <view class="q-answer">答案：{{item.answer}}</view>
        <view class="q-explanation" wx:if="{{item.explanation}}">解析：{{item.explanation}}</view>
      </view>
    </checkbox-group>
  </view>

  <view class="fix-bottom" wx:if="{{questions.length}}">
    <button class="bottom-btn" bindtap="onRepublish">📤 重新发布</button>
    <button class="bottom-btn" bindtap="onMoveToGroup">📁 移动到组</button>
    <button class="bottom-btn danger" bindtap="onRemoveFromGroup">🗑 从组中移除</button>
  </view>

  <!-- 班级选择弹窗 -->
  <view class="modal" wx:if="{{showClassModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">选择班级</text>
      <input class="title-input" placeholder="自定义标题（可选，如：期中复习测验）" value="{{customTitle}}" bindinput="onCustomTitle" maxlength="50" />
      <view class="class-item {{selClassId===item._id?'active':''}}" wx:for="{{classList}}" wx:key="_id" bindtap="onSelectClass" data-id="{{item._id}}">{{item.name}}</view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmRepublish">确认发布</button>
      </view>
    </view>
  </view>

  <!-- 组选择弹窗 -->
  <view class="modal" wx:if="{{showGroupModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">移动到组</text>
      <view class="class-item {{selGroupId===item._id?'active':''}}" wx:for="{{groupList}}" wx:key="_id" bindtap="onSelectTargetGroup" data-id="{{item._id}}">
        <text>{{item.name}}</text>
      </view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmMove">确认移动</button>
      </view>
    </view>
  </view>
</view>
