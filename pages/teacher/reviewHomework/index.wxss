.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.header { padding: 30rpx; background: #fff; margin-bottom: 20rpx; }
.hw-title { font-size: 34rpx; font-weight: bold; color: #333; display: block; margin-bottom: 12rpx; }
.hw-info { display: flex; flex-wrap: wrap; gap: 10rpx 30rpx; }
.hw-info text { font-size: 24rpx; color: #888; }

.search-bar { padding: 0 30rpx 20rpx; }
.search-input {
  width: 100%; height: 80rpx; background: #fff; border-radius: 40rpx;
  padding: 0 30rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #eee;
}

.loading { text-align: center; color: #999; padding-top: 100rpx; font-size: 28rpx; }
.empty { text-align: center; color: #999; padding-top: 100rpx; font-size: 28rpx; }

.student-list { padding: 0 24rpx; }
.student-item {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx;
  margin-bottom: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.student-item.clickable:active { background: #f5f5f5; }
.student-item.disabled { opacity: 0.55; }
.student-left { display: flex; flex-direction: column; }
.student-name { font-size: 30rpx; color: #333; font-weight: bold; }
.student-code { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.student-right { display: flex; align-items: center; gap: 12rpx; }
.rate { font-size: 28rpx; color: #667eea; font-weight: bold; }
.status-tag.not-submit { font-size: 24rpx; color: #999; padding: 6rpx 16rpx; background: #f0f0f0; border-radius: 20rpx; }
.arrow { font-size: 30rpx; color: #ccc; }
