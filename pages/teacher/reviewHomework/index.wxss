.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.header {
  padding: 30rpx; background: #fff; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.hw-title { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 14rpx; }
.hw-meta { display: flex; justify-content: space-between; }
.hw-class, .hw-meta text { font-size: 24rpx; color: #888; }

.search-bar { padding: 0 30rpx 20rpx; }
.search-input {
  width: 100%; height: 80rpx; background: #fff; border-radius: 40rpx;
  padding: 0 30rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #eee;
}

.hint-bar { padding: 0 30rpx 16rpx; font-size: 24rpx; color: #999; }

.loading { text-align: center; color: #999; padding-top: 100rpx; font-size: 28rpx; }
.empty {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 160rpx; font-size: 28rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { color: #999; margin-top: 16rpx; }

.student-list { padding: 0 30rpx; }
.student-card {
  background: #fff; border-radius: 16rpx; padding: 28rpx 30rpx;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.student-card.clickable:active { background: #f8f9fa; }
.student-card.disabled { opacity: 0.55; }

.card-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 14rpx;
}
.card-name { font-size: 32rpx; font-weight: 600; color: #333; }
.card-badge {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; font-weight: 500;
}
.card-badge.badge-ok { background: #e8f5e9; color: #27ae60; }
.card-badge.badge-no { background: #f0f0f0; color: #999; }

.card-meta {
  display: flex; justify-content: space-between; margin-bottom: 14rpx;
}
.card-code { font-size: 24rpx; color: #888; }
.card-rate { font-size: 28rpx; color: #667eea; font-weight: 600; }

.card-footer {
  border-top: 1rpx solid #f0f0f0; padding-top: 16rpx;
}
.card-tip { font-size: 22rpx; color: #aaa; }
