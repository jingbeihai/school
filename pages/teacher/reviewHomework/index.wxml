<view class="container">
  <!-- 作业信息 -->
  <view class="header" wx:if="{{homework}}">
    <text class="hw-title">{{homework.title}}</text>
    <view class="hw-info">
      <text>班级：{{homework.className || '未知'}}</text>
      <text wx:if="{{homework.deadline}}">截止：{{homework.deadline}}</text>
    </view>
  </view>

  <!-- 搜索 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索学生姓名或学号" value="{{searchKey}}" bindinput="onSearch" />
  </view>

  <!-- 列表 -->
  <view wx:if="{{loading && !students.length}}" class="loading">加载中...</view>
  <block wx:elif="{{!filteredStudents.length}}">
    <view class="empty">
      <text>{{students.length ? '没有匹配的学生' : '暂无学生数据'}}</text>
    </view>
  </block>

  <view class="student-list" wx:else>
    <view
      class="student-item {{item.status === 'submitted' ? 'clickable' : 'disabled'}}"
      wx:for="{{filteredStudents}}"
      wx:key="studentId"
      bindtap="goDetail"
      data-student="{{item}}"
    >
      <view class="student-left">
        <text class="student-name">{{item.name}}</text>
        <text class="student-code">{{item.userCode}}</text>
      </view>
      <view class="student-right">
        <text wx:if="{{item.status === 'submitted'}}" class="rate">{{item.correctCount}}/{{item.totalCount}}</text>
        <text wx:else class="status-tag not-submit">未提交</text>
        <text wx:if="{{item.status === 'submitted'}}" class="arrow">〉</text>
      </view>
    </view>
  </view>
</view>
