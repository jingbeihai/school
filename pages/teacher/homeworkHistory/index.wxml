<!-- pages/teacher/homeworkHistory/index.wxml -->
<view class="container">
  <view wx:if="{{list.length===0}}" class="empty">
    <text class="empty-icon">📚</text>
    <text class="empty-text">暂无已发布作业</text>
  </view>

  <view class="hw-list" wx:else>
    <view class="hint-bar">💡 长按作业可撤回或删除</view>
    <view class="hw-item {{item.status==='withdrawn'?'withdrawn':''}}" wx:for="{{list}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}" bindlongtap="onLongPress" data-id="{{item._id}}" data-title="{{item.title}}" data-status="{{item.status}}">
      <view class="hw-info">
        <text class="hw-title">{{item.title}}<text class="withdrawn-tag" wx:if="{{item.status==='withdrawn'}}">已撤回</text></text>
        <text class="hw-class">班级：{{item.className || '未知'}}</text>
        <text class="hw-meta">{{item.questionCount}}题 · {{item.publishTime}}</text>
        <text class="hw-deadline">截止：{{item.deadline}}</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>
</view>
