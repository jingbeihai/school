<!-- pages/teacher/homeworkDetail/index.wxml -->
<view class="container">
  <view class="header" wx:if="{{homework}}">
    <text class="hw-title">{{homework.title}}</text>
    <text class="hw-meta">发布时间：{{homework.publishTime}}</text>
    <text class="hw-deadline">截止时间：{{homework.deadline}}</text>
  </view>

  <view wx:if="{{questions.length===0}}" class="empty">
    <text class="empty-text">暂无题目</text>
  </view>

  <view wx:else>
    <view class="select-bar">
      <text class="select-all" bindtap="onSelectAll">{{allSelected?'取消全选':'全选'}}</text>
    </view>
    <checkbox-group bindchange="onCheckboxChange">
      <view class="q-card" wx:for="{{questions}}" wx:key="_id">
        <view class="q-row">
          <checkbox value="{{item._id}}" checked="{{item.checked}}" />
          <view class="q-body">
            <view class="q-type {{item.type}}">{{typeLabel[item.type]}}</view>
            <text class="q-content">{{item.content}}</text>
          </view>
        </view>
      </view>
    </checkbox-group>
  </view>

  <view class="fix-bottom" wx:if="{{questions.length}}">
    <button class="bottom-btn" bindtap="onRepublish">📤 重新发布</button>
    <button class="bottom-btn" bindtap="onCollect">📁 收藏到组</button>
  </view>

  <!-- 班级选择弹窗 -->
  <view class="modal" wx:if="{{showClassModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">选择班级</text>
      <input class="title-input" placeholder="自定义标题（可选，如：期中复习测验）" value="{{customTitle}}" bindinput="onCustomTitle" maxlength="50" />
      <view class="class-item {{selClassId===item._id?'active':''}}" wx:for="{{classList}}" wx:key="_id" bindtap="onSelectClass" data-id="{{item._id}}">{{item.name}}</view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmRepublish">确认发布</button>
      </view>
    </view>
  </view>

  <!-- 收藏弹窗 -->
  <view class="modal" wx:if="{{showGroupModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <text class="modal-title">添加到收藏组</text>
      <view class="class-item {{selGroupId===item._id?'active':''}}" wx:for="{{groupList}}" wx:key="_id" bindtap="onSelectGroup" data-id="{{item._id}}">
        <text>{{item.name}}</text>
      </view>
      <view class="new-group" bindtap="onNewGroup">+ 新建收藏组</view>
      <view class="modal-btns">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmCollect">确认添加</button>
      </view>
    </view>
  </view>
</view>
