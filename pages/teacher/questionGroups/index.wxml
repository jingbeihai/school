<!-- pages/teacher/questionGroups/index.wxml -->
<view class="container">
  <view wx:if="{{groups.length===0}}" class="empty">
    <text class="empty-icon">📁</text>
    <text class="empty-text">暂无收藏组</text>
    <button class="btn-new" bindtap="onNewGroup">+ 新建收藏组</button>
  </view>

  <view class="group-list" wx:else>
    <view class="group-item" wx:for="{{groups}}" wx:key="_id" bindtap="goGroupDetail" data-id="{{item._id}}" bindlongtap="onDeleteGroup" data-index="{{index}}">
      <view class="group-info">
        <text class="group-name">{{item.name}}</text>
        <text class="group-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <text class="group-meta">{{item.questionCount || 0}}题 · {{item.updateTime}}</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>

  <view class="fab" bindtap="onNewGroup">+</view>
</view>
