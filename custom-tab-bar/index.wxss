.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  font-size: 38rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: #667eea;
  font-weight: 600;
}
